# Keep source and plugin metadata portable across Windows, macOS, and Linux.
* text=auto

.gitattributes text eol=lf
.gitignore text eol=lf
LICENSE text eol=lf
NOTICE text eol=lf

*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf

# Windows-native scripts may keep CRLF if added later.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf